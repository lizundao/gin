---
import { logos } from 'virtual:starlight/user-images';
import config from 'virtual:starlight/user-config';

const { siteTitle } = Astro.locals.starlightRoute;
const siteTitleHref = '/';
const hasLogo = config.logo && logos.dark;
---

<a href={siteTitleHref} class="site-title-wrap">
	{
		hasLogo && (
			<img
				class:list={[
					'site-title-logo',
					{ 'light:sl-hidden print:hidden': !('src' in config.logo!) },
				]}
				alt={config.logo!.alt}
				src={logos.dark.src}
				width={logos.dark.width}
				height={logos.dark.height}
			/>
		)
	}
	{
		hasLogo && !('src' in config.logo!) && logos.light && (
			<img
				class="site-title-logo dark:sl-hidden print:block"
				alt={config.logo!.alt}
				src={logos.light.src}
				width={logos.light.width}
				height={logos.light.height}
			/>
		)
	}
	<span class="site-title-text">
		<span class="site-title-main">{siteTitle}</span>
		<span class="site-title-sub">.wiki</span>
	</span>
</a>
